@model List<Projeto5_Valcan.Models.JiraIssue>

@if (Model == null || !Model.Any())
{
    <div class="alert-dark-info">
        Nenhum Epic encontrado.
    </div>
}
else
{
    @foreach (var epic in Model)
    {
        var percent = GetProgressPercent(epic.Status);
        var barColor = GetBarColor(percent);
        var percentClass = percent >= 80 ? "high" : percent >= 40 ? "mid" : "low";

        <div class="delivery-item">
            <div class="delivery-header">
                <div class="delivery-name">
                    <span class="delivery-key">@epic.Key</span>
                    <span class="delivery-title">@epic.Summary</span>
                </div>
                <div class="delivery-sprint">
                    <span class="status-badge @GetStatusClass(epic.Status)">@epic.Status</span>
                </div>
            </div>
            <div class="progress-bar-track">
                <div class="progress-bar-fill @barColor" style="width: @(percent)%"></div>
            </div>
            <div class="delivery-meta">
                <span>👤 @epic.Assignee &nbsp; · &nbsp; 🏷️ @epic.IssueType</span>
                <span class="delivery-percent @percentClass">@(percent)%</span>
            </div>
        </div>
    }
}

@functions {
    int GetProgressPercent(string status)
    {
        return status.ToLower() switch
        {
            "done" or "concluído" or "closed" => 100,
            "in progress" or "em progresso" => 55,
            "in review" or "em revisão" => 80,
            "to do" or "a fazer" => 10,
            _ => 25
        };
    }

    string GetBarColor(int percent)
    {
        return percent switch
        {
            >= 90 => "green",
            >= 60 => "teal",
            >= 40 => "blue",
            >= 20 => "yellow",
            _ => "red"
        };
    }

    string GetStatusClass(string status)
    {
        return status.ToLower() switch
        {
            "in progress" or "em progresso" => "status-progress",
            "to do" or "a fazer" => "status-todo",
            "in review" or "em revisão" => "status-review",
            "done" or "concluído" => "status-done",
            _ => "status-todo"
        };
    }
}
