<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VALCANN</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Projeto5_Valcan.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <h4>🟢 VALCANN</h4>
            <small>Last synced: agora · Sprint 24</small>
        </div>

        <div class="sidebar-label">NAVIGATION</div>
        <ul class="sidebar-nav">
            <li><a href="@Url.Action("Index", "Dashboard")"><span class="nav-icon">📊</span> Dashboard</a></li>
            <li><a href="@Url.Action("Projects", "Dashboard")"><span class="nav-icon">📁</span> Projects</a></li>
            
            <li><a href="@Url.Action("Privacy", "Home")"><span class="nav-icon">⚙️</span> Settings</a></li>
        </ul>

        <div class="sidebar-user">
            <div class="avatar">AK</div>
            <div class="user-info">
                <div class="name">Valcann User</div>
                <div class="role">Team Lead</div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
